{
  "name": "@cateds/opencode-pty",
  "version": "0.4.1",
  "description": "OpenCode plugin for interactive PTY management - run background processes, send input, read output with regex filtering",
  "author": "cateds",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "pty",
    "pseudo-terminal",
    "terminal",
    "background-process",
    "interactive",
    "cli",
    "shell",
    "dev-server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cateds/opencode-plugins.git",
    "directory": "packages/opencode-pty"
  },
  "bugs": {
    "url": "https://github.com/cateds/opencode-plugins/issues"
  },
  "homepage": "https://github.com/cateds/opencode-plugins/tree/main/packages/opencode-pty#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./*/*": {
      "types": "./dist/src/*/*.d.ts",
      "default": "./dist/src/*/*.js"
    },
    "./*/*/*": {
      "types": "./dist/src/*/*/*.d.ts",
      "default": "./dist/src/*/*/*.js"
    },
    "./*/*/*/*": {
      "types": "./dist/src/*/*/*/*.d.ts",
      "default": "./dist/src/*/*/*/*.js"
    }
  },
  "imports": {
    "#pty": {
      "bun": "./dist/src/plugin/pty/pty.bun.js",
      "node": "./dist/src/plugin/pty/pty.node.js",
      "default": "./dist/src/plugin/pty/pty.bun.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "PW_DISABLE_TS_ESM=1 NODE_ENV=test playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-txt.js",
    "build:dev": "npm run clean && npm run build && vite build --mode development",
    "build:prod": "npm run clean && npm run build && vite build --mode production",
    "prepack": "npm run build:prod",
    "clean": "rm -rf dist playwright-report test-results",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write ."
  },
  "dependencies": {
    "@lydell/node-pty": "^1.0.0",
    "@opencode-ai/plugin": "^1.3.13",
    "@opencode-ai/sdk": "^1.3.13",
    "open": "^11.0.0",
    "semver": "^7.6.0",
    "strip-ansi": "^7.1.0",
    "ws": "^8.18.0",
    "zod": "^4.1.8"
  },
  "optionalDependencies": {
    "bun-pty": "^0.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "1.57.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/semver": "^7.5.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "happy-dom": "^20.5.0",
    "jsdom": "^27.4.0",
    "playwright-core": "1.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0",
    "opencode": ">=1.3.13"
  }
}
